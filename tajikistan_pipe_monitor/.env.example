# === LLM Provider ===
# Выберите провайдера: gemini или anthropic
LLM_PROVIDER=gemini

# Google Gemini API Key (основной бэкенд)
# Получить: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# Anthropic Claude API Key (альтернативный бэкенд)
# Получить: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Firecrawl API Key (для веб-скрапинга)
# Получить: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# === Настройки проекта ===
MIN_PIPE_DIAMETER_MM=400
TARGET_COUNTRY=Tajikistan
OUTPUT_DIR=output
LOG_LEVEL=INFO

# === Компании ===
COMPANY_NAME=composite.tj
CONTRACTOR_NAME=Барс
PRODUCTS=GRP pipes DN 400-3000mm
